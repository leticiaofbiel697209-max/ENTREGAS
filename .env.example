GESTAOCLICK_URL=https://api.gestaoclick.com
GESTAOCLICK_TOKEN=coloque_seu_token_aqui
GESTAOCLICK_SECRET_TOKEN=coloque_seu_secret_access_token_aqui
GESTAOCLICK_LOJA_ID=
# Obrigatorio para confirmar entrega sem risco financeiro:
# use o ID exato da situacao correta no GestaoClick.
GESTAOCLICK_STATUS_ENTREGUE_ID=

ADMIN_USER=admin
ADMIN_PASSWORD=123456

# Opcional para persistencia em nuvem.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Opcional: timeout das chamadas ao GestaoClick, em segundos.
GESTAOCLICK_TIMEOUT=30
